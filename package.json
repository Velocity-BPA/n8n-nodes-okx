{
  "name": "n8n-nodes-okx",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for OKX cryptocurrency exchange providing 11 resources and 100+ operations for trading, market data, funding, and automation. Includes grid trading, copy trading, and staking support.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-okx.git"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "okx",
    "cryptocurrency",
    "exchange",
    "trading",
    "crypto",
    "bitcoin",
    "ethereum",
    "defi",
    "spot",
    "futures",
    "perpetual",
    "swap",
    "options",
    "grid-trading",
    "copy-trading",
    "staking"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OkxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Okx/Okx.node.js",
      "dist/nodes/Okx/OkxTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "n8n-workflow": "1.57.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}